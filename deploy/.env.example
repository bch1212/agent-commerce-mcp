# Agent Commerce MCP — env template

# ─── Server ─────────────────────────────────────────────────────────────
MCP_SERVER_NAME=agent-commerce-mcp
MCP_TRANSPORT=http
PORT=3100
CATALOG_PATH=/app/catalog
BASE_URL=https://commerce.halversonco.com

# ─── Stripe (live) ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=https://halversonco.com/success?session={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://halversonco.com/cancel

# ─── Gumroad ────────────────────────────────────────────────────────────
GUMROAD_ACCESS_TOKEN=...

# ─── AgentTrust ─────────────────────────────────────────────────────────
AGENTTRUST_MCP_ENDPOINT=https://mcp-agenttrust-production.up.railway.app/mcp
AGENTTRUST_VENDOR_ID=halversoniq

# ─── Salesbot integration ───────────────────────────────────────────────
SALESBOT_WEBHOOK_URL=https://salesbot.halversonco.com/commerce/events
SALESBOT_ADMIN_TOKEN=...

# ─── Discord ────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
